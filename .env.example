# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# ─── AI (server-side only — set via Supabase secrets) ─────────────────────────
# These keys are stored as Supabase Edge Function secrets and never exposed to
# the browser. Set them once with:
#   supabase secrets set ANTHROPIC_API_KEY=...
#   supabase secrets set GOOGLE_GENERATIVE_AI_API_KEY=...
#
# ANTHROPIC_API_KEY=...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# Optional: Import Assistant modal still calls Gemini from the browser — prefer a future
# Edge Function so this key is not bundled. Uncomment only if you use that feature locally:
# VITE_GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─── Billing (Stripe) — server-side only, never expose to client ──────────────
# STRIPE_SECRET_KEY=sk_live_...      ← Edge Function / server env var only
# STRIPE_WEBHOOK_SECRET=whsec_...    ← Edge Function / server env var only

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# VITE_ENABLE_GEO_MATRIX=true
